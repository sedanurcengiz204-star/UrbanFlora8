rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'createdAt'])
        && data.keys().size() == 4
        && data.uid is string && data.uid.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 128
        && data.createdAt is timestamp;
    }
    
    function isValidPlant(data) {
      return data.keys().hasAll(['id', 'name', 'scientificName', 'category', 'image', 'desc', 'ownerId', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.scientificName is string && data.scientificName.size() <= 100
        && data.category is string && data.category.size() <= 100
        && data.image is string && data.image.size() <= 1000
        && data.desc is string && data.desc.size() <= 5000
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.createdAt is timestamp
        && data.ownerId == request.auth.uid;
    }
    
    // Collection matches
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
        && incoming().uid == userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if false;
    }
    
    match /plants/{plantId} {
      allow read, list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(plantId) && isValidPlant(incoming()) 
        && incoming().createdAt == request.time
        && incoming().id == plantId;
        
      allow update: if isSignedIn() && request.auth.uid == existing().ownerId
        && isValidId(plantId)
        && isValidPlant(incoming())
        && incoming().id == existing().id
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'scientificName', 'category', 'image', 'desc', 'lat', 'lng', 'rarity', 'scope', 'distance', 'date', 'habitat', 'features', 'uploader']);
        
      allow delete: if isSignedIn() && request.auth.uid == existing().ownerId;
    }
  }
}
